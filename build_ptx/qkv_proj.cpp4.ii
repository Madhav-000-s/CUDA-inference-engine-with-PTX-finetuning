    uint32_t acc45 = 0u;  
    uint32_t acc67 = 0u;  

    for (int i0 = tid * 8; i0 < in_dim; i0 += BLOCK * 8) {
        
        uint32_t w_lo, w_hi;
        asm volatile("ld.global.nc.v2.u32 {%0, %1}, [%2];"
                     : "=r"(w_lo), "=r"(w_hi)
                     : "l"(W_row + i0));

        
        uint32_t a01, a23, a45, a67;
        asm volatile("ld.global.nc.v4.u32 {%0, %1, %2, %3}, [%4];"
                     : "=r"(a01), "=r"(a23), "=r"(a45), "=r"(a67)
                     : "l"(x + i0));

        
        
        
        
        uint32_t b0, b1, b2, b3, b4, b5, b6, b7;
        asm("cvt.s32.s8 %0, %1;" : "=r"(b0) : "r"(w_lo));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b1) : "r"(w_lo >> 8));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b2) : "r"(w_lo >> 16));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b3) : "r"(w_lo >> 24));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b4) : "r"(w_hi));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b5) : "r"(w_hi >> 8));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b6) : "r"(w_hi >> 16));
        asm("cvt.s32.s8 %0, %1;" : "=r"(b7) : "r"(w_hi >> 24));

        
        
        
        uint32_t s16x2_01, s16x2_23, s16x2_45, s16x2_67;
        asm("prmt.b32 %0, %1, %2, 0x5410;" : "=r"(s16x2_01) : "r"(b0), "r"(b1));
        asm("prmt.b32 %0, %1, %2, 0x5410;" : "=r"(s16x2_23) : "r"(b2), "r"(b3));
        asm("prmt.b32 %0, %1, %2, 0x5410;" : "=r"(s16x2_45) : "r"(b4), "r"(b5));
        asm("prmt.b32 %0, %1, %2, 0x5410;" : "=r"(s16x2_67) : "r"(b6), "r"(b7));

        
        uint32_t w_f01, w_f23, w_f45, w_f67;
        asm("cvt.rn.f16x2.s16x2 %0, %1;" : "=r"(w_f01) : "r"(s16x2_01));
        asm("cvt.rn.f16x2.s16x2 %0, %1;" : "=r"(w_f23) : "r"(s16x2_23));
        asm("cvt.rn.f16x2.s16x2 %0, %1;" : "=r"(w_f45) : "r"(s16x2_45));
        asm("cvt.rn.f16x2.s16x2 %0, %1;" : "=r"(w_f67) : "r"(s16x2_67));

        
        asm("fma.rn.f16x2 %0, %1, %2, %0;"
