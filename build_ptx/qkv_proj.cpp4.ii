template <class _Ty>
[[nodiscard]] constexpr _Ty _Min_limit() noexcept { 
    ; 
    if constexpr (is_signed_v<_Ty>) {
        constexpr auto _Unsigned_max = static_cast<make_unsigned_t<_Ty>>(-1);
        return static_cast<_Ty>((_Unsigned_max >> 1) + 1); 
