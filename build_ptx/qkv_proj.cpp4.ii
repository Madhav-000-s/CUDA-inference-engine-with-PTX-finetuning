namespace tllm {


template <typename T>
class DeviceBuffer {
   public:
    DeviceBuffer() = default;
    explicit DeviceBuffer(size_t n) { resize(n); }
    DeviceBuffer(const DeviceBuffer&) = delete;
    DeviceBuffer& operator=(const DeviceBuffer&) = delete;
    DeviceBuffer(DeviceBuffer&& o) noexcept : ptr_(o.ptr_), n_(o.n_) {
        o.ptr_ = nullptr; o.n_ = 0;
    }
    DeviceBuffer& operator=(DeviceBuffer&& o) noexcept {
        if (this != &o) { free_(); ptr_ = o.ptr_; n_ = o.n_; o.ptr_ = nullptr; o.n_ = 0; }
        return *this;
    }
    ~DeviceBuffer() { free_(); }

    void resize(size_t n) {
        free_();
        n_ = n;
        if (n) do { cudaError_t _err = (cudaMalloc(&ptr_, n * sizeof(T))); if (_err != cudaSuccess) { fprintf((__acrt_iob_func(2)), "CUDA error %s at %s:%d: %s\n", cudaGetErrorString(_err), "C:\\Users\\super\\OneDrive\\Documents\\Projects\\CUDA inference engine with PTX fine-tuning\\include\\tensor.hpp", 41, "cudaMalloc(&ptr_, n * sizeof(T))"); std::exit(1); } } while (0);
    }
    void copy_from_host(const void* src, size_t n_bytes) {
        do { cudaError_t _err = (cudaMemcpy(ptr_, src, n_bytes, cudaMemcpyHostToDevice)); if (_err != cudaSuccess) { fprintf((__acrt_iob_func(2)), "CUDA error %s at %s:%d: %s\n", cudaGetErrorString(_err), "C:\\Users\\super\\OneDrive\\Documents\\Projects\\CUDA inference engine with PTX fine-tuning\\include\\tensor.hpp", 44, "cudaMemcpy(ptr_, src, n_bytes, cudaMemcpyHostToDevice)"); std::exit(1); } } while (0);
    }
    void copy_to_host(void* dst, size_t n_bytes) const {
        do { cudaError_t _err = (cudaMemcpy(dst, ptr_, n_bytes, cudaMemcpyDeviceToHost)); if (_err != cudaSuccess) { fprintf((__acrt_iob_func(2)), "CUDA error %s at %s:%d: %s\n", cudaGetErrorString(_err), "C:\\Users\\super\\OneDrive\\Documents\\Projects\\CUDA inference engine with PTX fine-tuning\\include\\tensor.hpp", 47, "cudaMemcpy(dst, ptr_, n_bytes, cudaMemcpyDeviceToHost)"); std::exit(1); } } while (0);
    }

    T*       data()       { return ptr_; }
    const T* data() const { return ptr_; }
    size_t   size() const { return n_; }

   private:
    void free_() { if (ptr_) { cudaFree(ptr_); ptr_ = nullptr; } }
    T*     ptr_ = nullptr;
    size_t n_   = 0;
};

